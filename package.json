{
  "name": "chowbea-axios",
  "version": "2.0.0-alpha.21",
  "description": "Type-safe axios client with interactive TUI dashboard",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite/index.d.ts",
      "import": "./dist/vite/index.js"
    }
  },
  "bin": {
    "chowbea-axios": "bin/chowbea-axios.js"
  },
  "files": [
    "bin",
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "@opentui/core": "^0.1.90",
    "@opentui/react": "^0.1.90",
    "picocolors": "^1.1.1",
    "react": "^19.2.4",
    "toml": "^3.0.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "typescript": "^5.9.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "vite": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "keywords": [
    "axios",
    "api",
    "typescript",
    "openapi",
    "codegen",
    "cli",
    "tui"
  ],
  "homepage": "https://axios.chowbea.com",
  "bugs": {
    "url": "https://github.com/oddFEELING/chowbea-axios/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/oddFEELING/chowbea-axios.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "author": "Emmanuel Alawode"
}
