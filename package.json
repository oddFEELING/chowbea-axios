{
  "name": "chowbea-axios",
  "version": "2.3.0",
  "description": "Type-safe axios client with interactive TUI dashboard",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite/index.d.ts",
      "import": "./dist/vite/index.js"
    }
  },
  "bin": {
    "chowbea-axios": "bin/chowbea-axios.js"
  },
  "files": [
    "bin",
    "dist",
    "templates",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepublishOnly": "npm run build",
    "release:experimental": "npm ci && npm test && npm version prerelease --preid=alpha -m \"chore(release): v%s\" && git push --follow-tags",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:types": "vitest run --typecheck.only",
    "test:types:strict": "tsc --noEmit -p tsconfig.tests.strict.json",
    "bench": "vitest bench --run"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.3",
    "@opentui/core": "^0.4.2",
    "@opentui/react": "^0.4.2",
    "openapi-typescript": "^7.13.0",
    "openapi-typescript-helpers": "^0.1.0",
    "picocolors": "^1.1.1",
    "react": "^19.2.4",
    "toml": "^4.1.1",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.14",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "vite": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "keywords": [
    "axios",
    "api",
    "typescript",
    "openapi",
    "codegen",
    "cli",
    "tui"
  ],
  "homepage": "https://axios.chowbea.com",
  "bugs": {
    "url": "https://github.com/oddFEELING/chowbea-axios/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/oddFEELING/chowbea-axios.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "author": "Emmanuel Alawode"
}
