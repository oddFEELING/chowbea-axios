; openapi-typescript@7 declares a peer dependency on typescript ^5,
; but this repo runs on typescript 6 (chore(deps-dev): bump typescript
; from 5.9.3 to 6.0.3 in commit 9698a98). TS6 is API-compatible with
; TS5 for the compiler-API surface openapi-typescript uses, so accept
; the peer mismatch rather than holding back the project's TS version.
;
; Drop this line when openapi-typescript declares typescript ^6 as a
; peer (or widens the range).
legacy-peer-deps=true
